//@version=6
indicator("Swing Setup Scanner", overlay=true, max_labels_count=10, max_lines_count=5)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
i_ema_len       = input.int(20,   "EMA Length",             group="EMA", minval=1)
i_ema_src       = input.source(close, "Source",             group="EMA")
i_ema_tf        = input.timeframe("D", "EMA Timeframe",     group="EMA")
i_min_ema_bars  = input.int(21,   "Min Bars Same Side",     group="EMA", minval=5,
                      tooltip="21 bars ≈ 3 trading days on 1h. Price must stay on one side of EMA this long.")
i_bounce_pct    = input.float(5.0,"EMA Bounce Band %",      group="EMA", minval=0.5, step=0.5,
                      tooltip="Low (long) or High (short) must come within this % of EMA for a valid bounce.")

i_atr_len       = input.int(14,   "ATR Length",             group="ATR", minval=1)
i_atr_smooth    = input.string("RMA", "Smoothing",          group="ATR", options=["RMA", "SMA", "EMA", "WMA"])

i_piv_left      = input.int(3,    "Pivot Left Bars",        group="Trendline", minval=2)
i_piv_right     = input.int(3,    "Pivot Right Bars",       group="Trendline", minval=1)
i_min_tl_bars   = input.int(8,    "Min Draw Span (bars)",   group="Trendline", minval=3,
                      tooltip="Minimum span to draw the trendline at all. Blue = developing (KIV). 8 bars ≈ 1.5 days on 1h.")
i_min_sig_bars  = input.int(21,   "Min Signal Span (bars)", group="Trendline", minval=5,
                      tooltip="Minimum span for a valid breakout signal. 21 bars ≈ 3 trading days on 1h. Below this the line is blue (monitoring only).")
i_min_touches   = input.int(2,    "Min Touch Points",       group="Trendline", minval=2,
                      tooltip="Minimum number of candle highs/lows touching the trendline.")
i_wick_tol_pct  = input.float(0.3,"Wick Tolerance %",       group="Trendline", minval=0.0, step=0.1,
                      tooltip="Allow highs/lows to exceed trendline by this % before disqualifying.")
i_breakout_bars = input.int(3,    "Breakout Lookback Bars", group="Trendline", minval=1,
                      tooltip="Detect a trendline breakout within this many bars of the last closed bar.")

i_vol_lb        = input.int(5,    "Volume Lookback",        group="Volume", minval=2,
                      tooltip="Compare current bar volume to average of this many prior bars.")

// ─── DERIVED ─────────────────────────────────────────────────────────────────
float wick_tol   = i_wick_tol_pct / 100.0
float bounce_pct = i_bounce_pct   / 100.0

// ─── INDICATORS ──────────────────────────────────────────────────────────────
// gaps_off: forward-filled daily value, used for all logic
float ema_val  = request.security(syminfo.tickerid, i_ema_tf, ta.ema(i_ema_src, i_ema_len), lookahead=barmerge.lookahead_off)
// gaps_on: na between daily closes — plot() connects them visually
float ema_plot = request.security(syminfo.tickerid, i_ema_tf, ta.ema(i_ema_src, i_ema_len), gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_off)

atr_ma(source, length) =>
    switch i_atr_smooth
        "RMA" => ta.rma(source, length)
        "SMA" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        =>       ta.wma(source, length)
float atr_val = atr_ma(ta.tr(true), i_atr_len)

// ─── EMA TREND FILTER ────────────────────────────────────────────────────────
// Strict close vs EMA for trend direction — bounce band is only for candle-pattern detection
bool above_ema = close >= ema_val

var int consec_above = 0
var int consec_below = 0
consec_above := above_ema ? consec_above + 1 : 0
consec_below := above_ema ? 0 : consec_below + 1

int cross_count = 0
for i = 1 to i_min_ema_bars - 1
    bool cur_side  = close[i]     >= ema_val[i]
    bool prev_side = close[i + 1] >= ema_val[i + 1]
    if cur_side != prev_side
        cross_count += 1

bool not_choppy   = cross_count <= 2
bool in_uptrend   = consec_above >= i_min_ema_bars and not_choppy
bool in_downtrend = consec_below >= i_min_ema_bars and not_choppy

// ─── PIVOT HISTORY ───────────────────────────────────────────────────────────
// Keep last 8 pivot highs/lows — scan all pairs for the best trendline
int MAX_PIVOTS = 8

float raw_ph = ta.pivothigh(high, i_piv_left, i_piv_right)
float raw_pl = ta.pivotlow(low,   i_piv_left, i_piv_right)

var array<float> ph_prices  = array.new<float>()
var array<int>   ph_bars_a  = array.new<int>()
var array<float> pl_prices  = array.new<float>()
var array<int>   pl_bars_a  = array.new<int>()

if not na(raw_ph)
    array.unshift(ph_prices, raw_ph)
    array.unshift(ph_bars_a, bar_index - i_piv_right)
    if array.size(ph_prices) > MAX_PIVOTS
        array.pop(ph_prices)
        array.pop(ph_bars_a)

if not na(raw_pl)
    array.unshift(pl_prices, raw_pl)
    array.unshift(pl_bars_a, bar_index - i_piv_right)
    if array.size(pl_prices) > MAX_PIVOTS
        array.pop(pl_prices)
        array.pop(pl_bars_a)

// ─── BOUNCE PATTERN TRACKING ─────────────────────────────────────────────────
var string last_bull_pattern  = "—"
var string last_bear_pattern  = "—"

// ─── EMA BOUNCE DETECTION ────────────────────────────────────────────────────
// Bullish (LONG setup): low came within bounce_pct of EMA + hammer or bull engulfing
bool low_near_ema   = low  >= ema_val * (1.0 - bounce_pct) and low  <= ema_val * (1.0 + bounce_pct)
bool is_hammer      = (high - low) > 0.0 and (close - low) / (high - low + 0.0001) >= 0.6 and close > open
bool is_bull_engulf = close > open and close > high[1] and open < close[1]
bool bull_bounce    = low_near_ema and (is_hammer or is_bull_engulf)

// Bearish (SHORT setup): high came within bounce_pct of EMA + shooting star or bear engulfing
bool high_near_ema  = high >= ema_val * (1.0 - bounce_pct) and high <= ema_val * (1.0 + bounce_pct)
bool is_star        = (high - low) > 0.0 and (high - close) / (high - low + 0.0001) >= 0.6 and close < open
bool is_bear_engulf = close < open and close < low[1] and open > close[1]
bool bear_bounce    = high_near_ema and (is_star or is_bear_engulf)

if bull_bounce
    last_bull_pattern := is_hammer ? "hammer" : "engulf"
if bear_bounce
    last_bear_pattern := is_star ? "star" : "engulf"

int bsince_bull = ta.barssince(bull_bounce)
int bsince_bear = ta.barssince(bear_bounce)

// ─── VOLUME & MOMENTUM ───────────────────────────────────────────────────────
float avg_vol   = ta.sma(volume, i_vol_lb + 1)
bool  vol_spike  = volume > avg_vol * 1.2
bool  mom_candle = (high - low) > 0.0 and math.abs(close - open) / (high - low) >= 0.6

// ─── HEAVY CHECKS (last bar only for performance) ────────────────────────────
var float ph1  = na
var int   ph1b = na
var float ph2  = na
var int   ph2b = na
var float pl1  = na
var int   pl1b = na
var float pl2  = na
var int   pl2b = na

var bool  long_piv_ok    = false
var bool  short_piv_ok   = false
var float long_slope     = na
var float short_slope    = na
var bool  long_no_wick   = false
var bool  short_no_wick  = false
var int   long_touches   = 0
var int   short_touches  = 0
var bool  long_bounce_ok = false
var bool  short_bounce_ok = false
var bool  long_breakout  = false
var bool  short_breakout = false

var int    long_breakout_ago  = na
var int    short_breakout_ago = na
var string long_grade         = "—"
var string short_grade        = "—"

if barstate.islast
    // Reset
    ph1  := na
    ph1b := na
    ph2  := na
    ph2b := na
    pl1  := na
    pl1b := na
    pl2  := na
    pl2b := na
    long_piv_ok     := false
    short_piv_ok    := false
    long_slope      := na
    short_slope     := na
    long_no_wick    := false
    short_no_wick   := false
    long_touches    := 0
    short_touches   := 0
    long_bounce_ok  := false
    short_bounce_ok := false
    long_breakout   := false
    short_breakout  := false
    long_breakout_ago  := na
    short_breakout_ago := na
    long_grade         := "—"
    short_grade        := "—"

    // ── Find best descending pair of pivot highs (LONG setup) ──────────────
    // Slope adjustment: anchor at p2 (older pivot), scan intermediate bars, and lift
    // the slope to the minimum needed to stay above all candle highs. If the adjusted
    // slope goes positive (can't draw a descending line without cutting through), skip
    // the pair. This happens when any bar between the two pivots exceeds p2's high.
    // See scripts/DEVELOPMENT.md for full debugging guide.
    int ph_n = array.size(ph_prices)
    for i = 0 to ph_n - 2
        if not long_piv_ok
            float p1 = array.get(ph_prices, i)
            int   b1 = array.get(ph_bars_a, i)
            for j = i + 1 to ph_n - 1
                if not long_piv_ok
                    float p2 = array.get(ph_prices, j)
                    int   b2 = array.get(ph_bars_a, j)
                    if p1 < p2 and (b1 - b2) >= i_min_tl_bars
                        float cand_slope = (p1 - p2) / float(b1 - b2)
                        int   cs = bar_index - b1
                        int   ce = math.min(bar_index - b2, cs + 200)
                        for k = cs to ce
                            float bfp2 = float(bar_index - k - b2)
                            if bfp2 > 0
                                float req = (high[k] - p2) / bfp2
                                if req > cand_slope
                                    cand_slope := req
                        if cand_slope <= 0
                            ph2        := p2
                            ph2b       := b2
                            ph1b       := b1
                            ph1        := p2 + cand_slope * float(b1 - b2)
                            long_slope := cand_slope
                            long_piv_ok := true

    // ── Find best ascending pair of pivot lows (SHORT setup) ───────────────
    int pl_n = array.size(pl_prices)
    for i = 0 to pl_n - 2
        if not short_piv_ok
            float p1 = array.get(pl_prices, i)
            int   b1 = array.get(pl_bars_a, i)
            for j = i + 1 to pl_n - 1
                if not short_piv_ok
                    float p2 = array.get(pl_prices, j)
                    int   b2 = array.get(pl_bars_a, j)
                    if p1 > p2 and (b1 - b2) >= i_min_tl_bars
                        float cand_slope = (p1 - p2) / float(b1 - b2)
                        int   cs = bar_index - b1
                        int   ce = math.min(bar_index - b2, cs + 200)
                        for k = cs to ce
                            float bfp2 = float(bar_index - k - b2)
                            if bfp2 > 0
                                float req = (low[k] - p2) / bfp2
                                if req < cand_slope
                                    cand_slope := req
                        if cand_slope >= 0
                            pl2         := p2
                            pl2b        := b2
                            pl1b        := b1
                            pl1         := p2 + cand_slope * float(b1 - b2)
                            short_slope := cand_slope
                            short_piv_ok := true

    // ── LONG trendline checks ──────────────────────────────────────────────
    if long_piv_ok
        long_no_wick := true
        int p1off = bar_index - ph1b
        int p2off = math.min(bar_index - ph2b, p1off + 200)

        for i = p1off to p2off
            float dist = float(bar_index - i - ph1b)
            float tl   = ph1 + long_slope * dist
            if tl > 0.0
                if high[i] > tl * (1.0 + wick_tol)
                    long_no_wick := false
                if math.abs(high[i] - tl) / tl <= 0.01
                    long_touches += 1

        // Bounce must happen AFTER ph1 (trendline forms first, then EMA bounce, then breakout)
        long_bounce_ok := not na(bsince_bull) and bsince_bull < (bar_index - ph1b)

        for i = 0 to i_breakout_bars - 1
            float tl_i  = ph1 + long_slope * float(bar_index -     i - ph1b)
            float tl_i1 = ph1 + long_slope * float(bar_index - i - 1 - ph1b)
            if close[i] > tl_i and close[i + 1] <= tl_i1
                long_breakout     := true
                long_breakout_ago := i

    // ── SHORT trendline checks ─────────────────────────────────────────────
    if short_piv_ok
        short_no_wick := true
        int q1off = bar_index - pl1b
        int q2off = math.min(bar_index - pl2b, q1off + 200)

        for i = q1off to q2off
            float dist = float(bar_index - i - pl1b)
            float tl   = pl1 + short_slope * dist
            if tl > 0.0
                if low[i] < tl * (1.0 - wick_tol)
                    short_no_wick := false
                if math.abs(low[i] - tl) / tl <= 0.01
                    short_touches += 1

        // Bounce must happen AFTER pl1
        short_bounce_ok := not na(bsince_bear) and bsince_bear < (bar_index - pl1b)

        for i = 0 to i_breakout_bars - 1
            float tl_i  = pl1 + short_slope * float(bar_index -     i - pl1b)
            float tl_i1 = pl1 + short_slope * float(bar_index - i - 1 - pl1b)
            if close[i] < tl_i and close[i + 1] >= tl_i1
                short_breakout     := true
                short_breakout_ago := i

    // ── Grade computation ──────────────────────────────────────────────────
    if long_piv_ok
        float tl_now     = ph1 + long_slope * float(bar_index - ph1b)
        bool approaching = tl_now > 0.0 and close < tl_now and (tl_now - close) / tl_now <= 0.02
        bool holding     = long_breakout and tl_now > 0.0 and close >= tl_now * 0.995
        if last_bull_pattern != "—"
            long_grade := (approaching or holding) ? "A" : "B"

    if short_piv_ok
        float tl_now     = pl1 + short_slope * float(bar_index - pl1b)
        bool approaching = tl_now > 0.0 and close > tl_now and (close - tl_now) / tl_now <= 0.02
        bool holding     = short_breakout and tl_now > 0.0 and close <= tl_now * 1.005
        if last_bear_pattern != "—"
            short_grade := (approaching or holding) ? "A" : "B"

// ─── SETUP SIGNALS ───────────────────────────────────────────────────────────
// Two-threshold design: i_min_tl_bars draws the line (blue = KIV), i_min_sig_bars
// gates the signal label. Trendlines < signal span are visual only (not in scanner).
bool long_span_ok  = long_piv_ok  and (ph1b - ph2b) >= i_min_sig_bars
bool short_span_ok = short_piv_ok and (pl1b - pl2b) >= i_min_sig_bars

bool long_setup = barstate.islast
             and in_uptrend
             and long_span_ok
             and long_no_wick
             and long_touches  >= i_min_touches
             and long_bounce_ok
             and long_breakout

bool short_setup = barstate.islast
              and in_downtrend
              and short_span_ok
              and short_no_wick
              and short_touches  >= i_min_touches
              and short_bounce_ok
              and short_breakout

// ─── SETUP GRADE ─────────────────────────────────────────────────────────────
string grade = "Moderate"
if vol_spike and mom_candle
    grade := "Ideal"
else if vol_spike or mom_candle
    grade := "Strong"

// ─── VISUAL TRENDLINES ───────────────────────────────────────────────────────
var line long_line  = na
var line short_line = na

if barstate.islast
    // LONG trendline: blue = developing (< signal span), orange = ready, green = breakout
    if long_piv_ok and long_no_wick and long_touches >= i_min_touches
        color tl_col = long_breakout     ? color.new(color.green, 0)
                     : long_span_ok      ? color.new(color.orange, 0)
                     :                     color.new(color.blue, 40)
        float proj = ph1 + long_slope * float(bar_index + 5 - ph1b)
        line.delete(long_line)
        long_line := line.new(ph2b, ph2, bar_index + 5, proj, color=tl_col, width=2)

    // SHORT trendline: only draw when price is in downtrend (below EMA).
    // Blue = developing (< signal span), orange = ready, red = breakout.
    if short_piv_ok and short_no_wick and short_touches >= i_min_touches and in_downtrend
        color tl_col = short_breakout    ? color.new(color.red, 0)
                     : short_span_ok     ? color.new(color.orange, 0)
                     :                     color.new(color.blue, 40)
        float proj = pl1 + short_slope * float(bar_index + 5 - pl1b)
        line.delete(short_line)
        short_line := line.new(pl2b, pl2, bar_index + 5, proj, color=tl_col, width=2)

// ─── MACHINE-READABLE LABEL OUTPUT ───────────────────────────────────────────
// Format: "DIRECTION|GRADE|TOUCHES|EMA_BARS|ATR"
// Example: "LONG|Ideal|3|45|0.87"
// Parsed by scanner_run_watchlist MCP tool.
var label long_lbl  = na
var label short_lbl = na

if long_setup
    string txt = "LONG|"  + grade + "|" + str.tostring(long_touches)  + "|"
               + str.tostring(consec_above) + "|" + str.tostring(atr_val, "#.####")
    label.delete(long_lbl)
    long_lbl := label.new(bar_index, high * 1.001, txt,
         style     = label.style_label_down,
         color     = color.new(color.green, 15),
         textcolor = color.white,
         size      = size.small)

if short_setup
    string txt = "SHORT|" + grade + "|" + str.tostring(short_touches) + "|"
               + str.tostring(consec_below) + "|" + str.tostring(atr_val, "#.####")
    label.delete(short_lbl)
    short_lbl := label.new(bar_index, low * 0.999, txt,
         style     = label.style_label_up,
         color     = color.new(color.red, 15),
         textcolor = color.white,
         size      = size.small)

// ─── PLOTS ───────────────────────────────────────────────────────────────────
plot(ema_plot, "Daily EMA 20", color=color.new(color.blue, 0), linewidth=1)

// ─── SETUP CONDITIONS TABLE ──────────────────────────────────────────────────
var table setup_tbl = table.new(position.top_right, 3, 5,
     bgcolor      = color.new(color.gray, 85),
     border_color = color.new(color.gray, 60),
     border_width = 1,
     frame_color  = color.new(color.gray, 40),
     frame_width  = 1)

if barstate.islast
    bool   is_long  = consec_above >= 1

    // Condition values
    bool   c_bounce = is_long ? (last_bull_pattern != "—") : (last_bear_pattern != "—")
    string d_bounce = is_long ? last_bull_pattern : last_bear_pattern

    bool   c_break  = is_long ? long_breakout : short_breakout
    int    b_ago    = is_long ? long_breakout_ago : short_breakout_ago
    string d_break  = not c_break ? "—" : (na(b_ago) or b_ago == 0) ? "now" : str.tostring(b_ago) + "b"

    int    vol_pct  = math.round((volume / avg_vol - 1) * 100)
    string d_vol    = (vol_pct >= 0 ? "+" : "") + str.tostring(vol_pct) + "%"

    int    body_pct = (high - low) > 0.0 ? math.round(math.abs(close - open) / (high - low) * 100) : 0
    string d_mom    = str.tostring(body_pct) + "%"

    string tbl_grade = is_long ? long_grade : short_grade
    string dir_txt   = is_long ? "▲ LONG" : "▼ SHORT"
    color  hdr_bg    = is_long ? color.new(color.green, 10) : color.new(color.red, 10)
    color  grade_bg  = tbl_grade == "A" ? color.new(color.green, 10) :
                       tbl_grade == "B" ? color.new(color.orange, 10) : hdr_bg
    color  c_met    = color.new(color.green, 20)
    color  c_nmet   = color.new(color.red,   20)
    color  c_det    = color.new(color.gray,  70)

    // Header row
    table.cell(setup_tbl, 0, 0, dir_txt,
         text_color=color.white, bgcolor=hdr_bg, text_size=size.small, text_halign=text.align_left)
    table.cell(setup_tbl, 1, 0, "",
         text_color=color.white, bgcolor=hdr_bg, text_size=size.small)
    table.cell(setup_tbl, 2, 0, tbl_grade != "—" ? "[" + tbl_grade + "]" : "",
         text_color=color.white, bgcolor=grade_bg, text_size=size.small, text_halign=text.align_right)

    // Row 1 — Bounce EMA
    table.cell(setup_tbl, 0, 1, "Bounce EMA",
         text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
    table.cell(setup_tbl, 1, 1, c_bounce ? "✓" : "✗",
         text_color=color.white, bgcolor=c_bounce ? c_met : c_nmet, text_size=size.small)
    table.cell(setup_tbl, 2, 1, d_bounce,
         text_color=color.white, bgcolor=c_det, text_size=size.small)

    // Row 2 — Breakout
    table.cell(setup_tbl, 0, 2, "Breakout",
         text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
    table.cell(setup_tbl, 1, 2, c_break ? "✓" : "✗",
         text_color=color.white, bgcolor=c_break ? c_met : c_nmet, text_size=size.small)
    table.cell(setup_tbl, 2, 2, d_break,
         text_color=color.white, bgcolor=c_det, text_size=size.small)

    // Row 3 — Volume
    table.cell(setup_tbl, 0, 3, "Volume",
         text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
    table.cell(setup_tbl, 1, 3, vol_spike ? "✓" : "✗",
         text_color=color.white, bgcolor=vol_spike ? c_met : c_nmet, text_size=size.small)
    table.cell(setup_tbl, 2, 3, d_vol,
         text_color=color.white, bgcolor=c_det, text_size=size.small)

    // Row 4 — Momentum
    table.cell(setup_tbl, 0, 4, "Momentum",
         text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
    table.cell(setup_tbl, 1, 4, mom_candle ? "✓" : "✗",
         text_color=color.white, bgcolor=mom_candle ? c_met : c_nmet, text_size=size.small)
    table.cell(setup_tbl, 2, 4, d_mom,
         text_color=color.white, bgcolor=c_det, text_size=size.small)
