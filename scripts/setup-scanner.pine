//@version=6
indicator("Swing Setup Scanner", overlay=true, max_labels_count=20, max_lines_count=5, max_boxes_count=4)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
i_ema_len       = input.int(20,   "EMA Length",             group="EMA", minval=1)
i_ema_src       = input.source(close, "Source",             group="EMA")
i_ema_tf        = input.timeframe("D", "EMA Timeframe",     group="EMA")
i_min_ema_bars  = input.int(21,   "Min Bars Same Side",     group="EMA", minval=5,
                      tooltip="21 bars ≈ 3 trading days on 1h. Price must stay on one side of EMA this long.")
i_bounce_pct    = input.float(5.0,"EMA Bounce Band %",      group="EMA", minval=0.5, step=0.5,
                      tooltip="Low (long) or High (short) must come within this % of EMA for a valid bounce.")

i_atr_len       = input.int(14,   "ATR Length",             group="ATR", minval=1)
i_atr_smooth    = input.string("RMA", "Smoothing",          group="ATR", options=["RMA", "SMA", "EMA", "WMA"])

i_piv_left      = input.int(3,    "Pivot Left Bars",        group="Trendline", minval=2)
i_piv_right     = input.int(3,    "Pivot Right Bars",       group="Trendline", minval=1)
i_min_tl_bars   = input.int(8,    "Min Draw Span (bars)",   group="Trendline", minval=3,
                      tooltip="Minimum span to draw the trendline at all. Blue = developing (KIV). 8 bars ≈ 1.5 days on 1h.")
i_min_sig_bars  = input.int(21,   "Min Signal Span (bars)", group="Trendline", minval=5,
                      tooltip="Minimum span for a valid breakout signal. 21 bars ≈ 3 trading days on 1h. Below this the line is blue (monitoring only).")
i_min_touches   = input.int(2,    "Min Touch Points",       group="Trendline", minval=2,
                      tooltip="Minimum number of candle highs/lows touching the trendline.")
i_wick_tol_pct  = input.float(0.3,"Wick Tolerance %",       group="Trendline", minval=0.0, step=0.1,
                      tooltip="Allow highs/lows to exceed trendline by this % before disqualifying.")
i_breakout_bars = input.int(3,    "Breakout Lookback Bars", group="Trendline", minval=1,
                      tooltip="Detect a trendline breakout within this many bars of the last closed bar.")
i_watch_pct     = input.float(3.0,"Watch Threshold %",      group="Trendline", minval=1.0, step=0.5,
                      tooltip="Show a WATCH signal when price is within this % below the trendline (no breakout yet).")

i_vol_lb        = input.int(5,    "Volume Lookback",        group="Volume", minval=2,
                      tooltip="Compare current bar volume to average of this many prior bars.")

// ─── DERIVED ─────────────────────────────────────────────────────────────────
float wick_tol   = i_wick_tol_pct / 100.0
float bounce_pct = i_bounce_pct   / 100.0

// ─── INDICATORS ──────────────────────────────────────────────────────────────
float ema_val  = request.security(syminfo.tickerid, i_ema_tf, ta.ema(i_ema_src, i_ema_len), lookahead=barmerge.lookahead_off)
float ema_plot = request.security(syminfo.tickerid, i_ema_tf, ta.ema(i_ema_src, i_ema_len), gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_off)

float daily_high_52w = request.security(syminfo.tickerid, "D", ta.highest(high, 252), lookahead=barmerge.lookahead_off)
float prev_day_high  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
bool  near_ath = not na(daily_high_52w) and close >= daily_high_52w * 0.95
bool  near_pdh = not na(prev_day_high)  and math.abs(close - prev_day_high) / prev_day_high <= 0.01

atr_ma(source, length) =>
    switch i_atr_smooth
        "RMA" => ta.rma(source, length)
        "SMA" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        =>       ta.wma(source, length)
float atr_val = atr_ma(ta.tr(true), i_atr_len)

// ─── EMA TREND FILTER ────────────────────────────────────────────────────────
bool above_ema = close >= ema_val

var int consec_above = 0
var int consec_below = 0
consec_above := above_ema ? consec_above + 1 : 0
consec_below := above_ema ? 0 : consec_below + 1

int cross_count = 0
for i = 1 to i_min_ema_bars - 1
    bool cur_side  = close[i]     >= ema_val[i]
    bool prev_side = close[i + 1] >= ema_val[i + 1]
    if cur_side != prev_side
        cross_count += 1

bool not_choppy   = cross_count <= 2
bool in_uptrend   = consec_above >= i_min_ema_bars and not_choppy
bool in_downtrend = consec_below >= i_min_ema_bars and not_choppy

// ─── PIVOT HISTORY ───────────────────────────────────────────────────────────
int MAX_PIVOTS = 8

float raw_ph = ta.pivothigh(high, i_piv_left, i_piv_right)
float raw_pl = ta.pivotlow(low,   i_piv_left, i_piv_right)

var array<float> ph_prices  = array.new<float>()
var array<int>   ph_bars_a  = array.new<int>()
var array<float> pl_prices  = array.new<float>()
var array<int>   pl_bars_a  = array.new<int>()

if not na(raw_ph)
    array.unshift(ph_prices, raw_ph)
    array.unshift(ph_bars_a, bar_index - i_piv_right)
    if array.size(ph_prices) > MAX_PIVOTS
        array.pop(ph_prices)
        array.pop(ph_bars_a)

if not na(raw_pl)
    array.unshift(pl_prices, raw_pl)
    array.unshift(pl_bars_a, bar_index - i_piv_right)
    if array.size(pl_prices) > MAX_PIVOTS
        array.pop(pl_prices)
        array.pop(pl_bars_a)

// ─── BOUNCE TRACKING ─────────────────────────────────────────────────────────
var string long_bounce_pat  = "—"
var int    long_bounce_bar  = na
var string short_bounce_pat = "—"
var int    short_bounce_bar = na

// ─── VOLUME & MOMENTUM ───────────────────────────────────────────────────────
float avg_vol = ta.sma(volume, i_vol_lb + 1)

// ─── HEAVY CHECKS (last bar only for performance) ────────────────────────────
var float ph1  = na
var int   ph1b = na
var float ph2  = na
var int   ph2b = na
var float pl1  = na
var int   pl1b = na
var float pl2  = na
var int   pl2b = na

var bool  long_piv_ok     = false
var bool  short_piv_ok    = false
var float long_slope      = na
var float short_slope     = na
var bool  long_no_wick    = false
var bool  short_no_wick   = false
var int   long_touches    = 0
var int   short_touches   = 0
var bool  long_bounce_ok  = false
var bool  short_bounce_ok = false
var bool  long_breakout   = false
var bool  short_breakout  = false

var int  long_breakout_ago  = na
var int  long_any_cross_ago = na
var int  short_breakout_ago = na
var int  short_any_cross_ago = na
var bool long_holding       = false
var bool short_holding      = false

if barstate.islast
    ph1  := na
    ph1b := na
    ph2  := na
    ph2b := na
    pl1  := na
    pl1b := na
    pl2  := na
    pl2b := na
    long_piv_ok      := false
    short_piv_ok     := false
    long_slope       := na
    short_slope      := na
    long_no_wick     := false
    short_no_wick    := false
    long_touches     := 0
    short_touches    := 0
    long_bounce_ok   := false
    short_bounce_ok  := false
    long_breakout    := false
    short_breakout   := false
    long_breakout_ago   := na
    long_any_cross_ago  := na
    short_breakout_ago  := na
    short_any_cross_ago := na
    long_holding        := false
    short_holding       := false

    // ── LONG pivot pair ──
    if consec_above >= 1
        int ph_n = array.size(ph_prices)
        for i = 0 to ph_n - 2
            if not long_piv_ok
                float p1 = array.get(ph_prices, i)
                int   b1 = array.get(ph_bars_a, i)
                for j = i + 1 to ph_n - 1
                    if not long_piv_ok
                        float p2 = array.get(ph_prices, j)
                        int   b2 = array.get(ph_bars_a, j)
                        if p1 < p2 and (b1 - b2) >= i_min_tl_bars
                            float cand_slope = (p1 - p2) / float(b1 - b2)
                            int   cs = bar_index - b1
                            int   ce = math.min(bar_index - b2, cs + 200)
                            for k = cs to ce
                                float bfp2 = float(bar_index - k - b2)
                                if bfp2 > 0
                                    float req = (high[k] - p2) / bfp2
                                    if req > cand_slope
                                        cand_slope := req
                            if cand_slope <= 0
                                ph2         := p2
                                ph2b        := b2
                                ph1b        := b1
                                ph1         := p2 + cand_slope * float(b1 - b2)
                                long_slope  := cand_slope
                                long_piv_ok := true

    // ── SHORT pivot pair ──
    if consec_above == 0
        int pl_n = array.size(pl_prices)
        for i = 0 to pl_n - 2
            if not short_piv_ok
                float p1 = array.get(pl_prices, i)
                int   b1 = array.get(pl_bars_a, i)
                for j = i + 1 to pl_n - 1
                    if not short_piv_ok
                        float p2 = array.get(pl_prices, j)
                        int   b2 = array.get(pl_bars_a, j)
                        if p1 > p2 and (b1 - b2) >= i_min_tl_bars
                            float cand_slope = (p1 - p2) / float(b1 - b2)
                            int   cs = bar_index - b1
                            int   ce = math.min(bar_index - b2, cs + 200)
                            for k = cs to ce
                                float bfp2 = float(bar_index - k - b2)
                                if bfp2 > 0
                                    float req = (low[k] - p2) / bfp2
                                    if req < cand_slope
                                        cand_slope := req
                            if cand_slope >= 0
                                pl2          := p2
                                pl2b         := b2
                                pl1b         := b1
                                pl1          := p2 + cand_slope * float(b1 - b2)
                                short_slope  := cand_slope
                                short_piv_ok := true

    // ── Slope lift: weak red close just above LONG trendline → treat as touch ──
    if long_piv_ok
        for k = 0 to math.min(bar_index - ph1b, 200)
            float bfp2 = float(bar_index - k - ph2b)
            if bfp2 > 0
                float tl_k = ph1 + long_slope * float(bar_index - k - ph1b)
                if tl_k > 0.0 and close[k] > tl_k and close[k] <= tl_k * 1.005 and close[k] < open[k]
                    float req = (close[k] - ph2) / bfp2
                    if req > long_slope
                        long_slope := req
                        ph1        := ph2 + long_slope * float(ph1b - ph2b)
        if long_slope > 0.0
            long_piv_ok := false

    // ── Slope lift: weak green close just below SHORT trendline → treat as touch ──
    if short_piv_ok
        for k = 0 to math.min(bar_index - pl1b, 200)
            float bfp2 = float(bar_index - k - pl2b)
            if bfp2 > 0
                float tl_k = pl1 + short_slope * float(bar_index - k - pl1b)
                if tl_k > 0.0 and close[k] < tl_k and close[k] >= tl_k * 0.995 and close[k] > open[k]
                    float req = (close[k] - pl2) / bfp2
                    if req < short_slope
                        short_slope := req
                        pl1         := pl2 + short_slope * float(pl1b - pl2b)
        if short_slope < 0.0
            short_piv_ok := false

    // ── LONG trendline checks ──────────────────────────────────────────────
    if long_piv_ok
        long_no_wick := true
        bool long_ema_clean = true
        int p1off = bar_index - ph1b
        int p2off = math.min(bar_index - ph2b, p1off + 200)
        for i = p1off to p2off
            float dist = float(bar_index - i - ph1b)
            float tl   = ph1 + long_slope * dist
            if tl > 0.0
                if high[i] > tl * (1.0 + wick_tol)
                    long_no_wick := false
                if math.abs(high[i] - tl) / tl <= 0.01
                    long_touches += 1
            if close[i] < ema_val[i] * 0.99
                long_ema_clean := false
        if not long_ema_clean
            long_piv_ok := false
        else
            int long_scan = math.min(bar_index - ph1b, 200)
            for i = 0 to long_scan
                float tl_i  = ph1 + long_slope * float(bar_index -     i - ph1b)
                float tl_i1 = ph1 + long_slope * float(bar_index - i - 1 - ph1b)
                if close[i] > tl_i and close[i + 1] <= tl_i1
                    long_breakout      := true
                    long_any_cross_ago := i
                    if close[i] > open[i]
                        long_breakout_ago := i

    // ── SHORT trendline checks ─────────────────────────────────────────────
    if short_piv_ok
        short_no_wick := true
        bool short_ema_clean = true
        int q1off = bar_index - pl1b
        int q2off = math.min(bar_index - pl2b, q1off + 200)
        for i = q1off to q2off
            float dist = float(bar_index - i - pl1b)
            float tl   = pl1 + short_slope * dist
            if tl > 0.0
                if low[i] < tl * (1.0 - wick_tol)
                    short_no_wick := false
                if math.abs(low[i] - tl) / tl <= 0.01
                    short_touches += 1
            if close[i] > ema_val[i] * 1.01
                short_ema_clean := false
        if not short_ema_clean
            short_piv_ok := false
        else
            int short_scan = math.min(bar_index - pl1b, 200)
            for i = 0 to short_scan
                float tl_i  = pl1 + short_slope * float(bar_index -     i - pl1b)
                float tl_i1 = pl1 + short_slope * float(bar_index - i - 1 - pl1b)
                if close[i] < tl_i and close[i + 1] >= tl_i1
                    short_breakout      := true
                    short_any_cross_ago := i
                    if close[i] < open[i]
                        short_breakout_ago := i

    // ── Bounce scan ──────────────────────────────────────────────────────
    long_bounce_bar  := na
    long_bounce_pat  := "—"
    long_bounce_ok   := false
    short_bounce_bar := na
    short_bounce_pat := "—"
    short_bounce_ok  := false

    if long_piv_ok
        int   bo_bar_l  = long_breakout ? (bar_index - long_any_cross_ago) : bar_index
        int   pl_cnt    = array.size(pl_bars_a)
        float best_dist = na
        for i = 0 to pl_cnt - 1
            int   pb = array.get(pl_bars_a, i)
            float pp = array.get(pl_prices, i)
            if pb >= ph2b and pb <= bo_bar_l
                int   op       = bar_index - pb
                float ema_pb   = ema_val[op]
                float tl_at_pb = ph1 + long_slope * float(pb - ph1b)
                if pp < tl_at_pb and close[op] < tl_at_pb
                    if pp >= ema_pb * (1.0 - bounce_pct) and pp <= ema_pb * (1.0 + bounce_pct * 2)
                        float dist_to_ema = math.abs(pp - ema_pb)
                        if na(best_dist) or dist_to_ema < best_dist
                            best_dist       := dist_to_ema
                            long_bounce_bar := pb
                            long_bounce_ok  := true
                            bool is_h = (high[op] - low[op]) > 0.0 and (close[op] - low[op]) / (high[op] - low[op] + 0.0001) >= 0.6 and close[op] > open[op]
                            bool is_e = close[op] > open[op] and close[op] > high[op + 1] and open[op] < close[op + 1]
                            long_bounce_pat := is_h ? "hammer" : is_e ? "engulf" : "swing"

    if short_piv_ok
        int   bo_bar_s  = short_breakout ? (bar_index - short_any_cross_ago) : bar_index
        int   ph_cnt    = array.size(ph_bars_a)
        float best_dist = na
        for i = 0 to ph_cnt - 1
            int   pb = array.get(ph_bars_a, i)
            float pp = array.get(ph_prices, i)
            if pb >= pl2b and pb <= bo_bar_s
                int   op       = bar_index - pb
                float ema_pb   = ema_val[op]
                float tl_at_pb = pl1 + short_slope * float(pb - pl1b)
                if pp > tl_at_pb and close[op] > tl_at_pb
                    if pp >= ema_pb * (1.0 - bounce_pct) and pp <= ema_pb * (1.0 + bounce_pct * 2)
                        float dist_to_ema = math.abs(pp - ema_pb)
                        if na(best_dist) or dist_to_ema < best_dist
                            best_dist        := dist_to_ema
                            short_bounce_bar := pb
                            short_bounce_ok  := true
                            bool is_s = (high[op] - low[op]) > 0.0 and (high[op] - close[op]) / (high[op] - low[op] + 0.0001) >= 0.6 and close[op] < open[op]
                            bool is_e = close[op] < open[op] and close[op] < low[op + 1] and open[op] > close[op + 1]
                            short_bounce_pat := is_s ? "star" : is_e ? "engulf" : "swing"

    // ── Holding check ─────────────────────────────────────────────────────
    if long_piv_ok
        float tl_now = ph1 + long_slope * float(bar_index - ph1b)
        long_holding := long_breakout and tl_now > 0.0 and close >= tl_now * 0.995 and close <= tl_now * 1.03

    if short_piv_ok
        float tl_now  = pl1 + short_slope * float(bar_index - pl1b)
        short_holding := short_breakout and tl_now > 0.0 and close <= tl_now * 1.005 and close >= tl_now * 0.97

// ─── SETUP SIGNALS ───────────────────────────────────────────────────────────
bool long_span_ok  = long_piv_ok  and (ph1b - ph2b) >= i_min_sig_bars
bool short_span_ok = short_piv_ok and (pl1b - pl2b) >= i_min_sig_bars

bool long_setup = barstate.islast
             and in_uptrend
             and long_span_ok
             and long_no_wick
             and long_touches  >= i_min_touches
             and long_bounce_ok
             and long_breakout
             and (long_breakout_ago <= i_breakout_bars or long_holding)

bool short_setup = barstate.islast
              and in_downtrend
              and short_span_ok
              and short_no_wick
              and short_touches  >= i_min_touches
              and short_bounce_ok
              and short_breakout
              and (short_breakout_ago <= i_breakout_bars or short_holding)

// ─── WATCH SIGNALS ─────────────────────────────────────────────────────────
float long_tl_now  = barstate.islast and long_piv_ok  ? ph1 + long_slope  * float(bar_index - ph1b)  : na
float short_tl_now = barstate.islast and short_piv_ok ? pl1 + short_slope * float(bar_index - pl1b) : na
float watch_band   = i_watch_pct / 100.0

// Bounce pattern quality — defined here so WATCH and SCORE blocks can both use them
bool sp_long  = long_bounce_pat  == "hammer" or long_bounce_pat  == "engulf"
bool sp_short = short_bounce_pat == "star"   or short_bounce_pat == "engulf"

// W1: approaching trendline + quality bounce candle (hammer / engulf)
bool long_watch1 = barstate.islast
             and in_uptrend and long_span_ok and long_no_wick
             and long_touches  >= i_min_touches and long_bounce_ok and sp_long
             and not long_breakout
             and not na(long_tl_now) and long_tl_now > 0.0
             and close < long_tl_now
             and (long_tl_now - close) / long_tl_now <= watch_band

// W2: approaching trendline + bounce ok but no quality candle pattern
bool long_watch2 = barstate.islast
             and in_uptrend and long_span_ok and long_no_wick
             and long_touches  >= i_min_touches and long_bounce_ok and not sp_long
             and not long_breakout
             and not na(long_tl_now) and long_tl_now > 0.0
             and close < long_tl_now
             and (long_tl_now - close) / long_tl_now <= watch_band

bool short_watch1 = barstate.islast
              and in_downtrend and short_span_ok and short_no_wick
              and short_touches >= i_min_touches and short_bounce_ok and sp_short
              and not short_breakout
              and not na(short_tl_now) and short_tl_now > 0.0
              and close > short_tl_now
              and (close - short_tl_now) / short_tl_now <= watch_band

bool short_watch2 = barstate.islast
              and in_downtrend and short_span_ok and short_no_wick
              and short_touches >= i_min_touches and short_bounce_ok and not sp_short
              and not short_breakout
              and not na(short_tl_now) and short_tl_now > 0.0
              and close > short_tl_now
              and (close - short_tl_now) / short_tl_now <= watch_band

// ─── DEVELOPING SIGNALS (almost-ready) ────────────────────────────────────
// Fires when all gates pass except span < min or consec < min (non-choppy)
// Emits S (quality bounce) or A (swing bounce) with scenario=DEV + countdown note

bool long_dev = barstate.islast
             and long_piv_ok and long_no_wick and long_touches >= i_min_touches and long_bounce_ok
             and not long_breakout and not na(long_tl_now) and long_tl_now > 0.0
             and close < long_tl_now and (long_tl_now - close) / long_tl_now <= watch_band
             and not (long_watch1 or long_watch2)
             and ((ph1b - ph2b) < i_min_sig_bars
                  or (long_span_ok and consec_above > 0 and consec_above < i_min_ema_bars and not_choppy))

bool short_dev = barstate.islast
              and short_piv_ok and short_no_wick and short_touches >= i_min_touches and short_bounce_ok
              and not short_breakout and not na(short_tl_now) and short_tl_now > 0.0
              and close > short_tl_now and (close - short_tl_now) / short_tl_now <= watch_band
              and not (short_watch1 or short_watch2)
              and ((pl1b - pl2b) < i_min_sig_bars
                   or (short_span_ok and consec_below > 0 and consec_below < i_min_ema_bars and not_choppy))

int ld_span_to_go   = (long_dev  and (ph1b - ph2b) < i_min_sig_bars)                       ? (i_min_sig_bars - (ph1b - ph2b))  : na
int ld_consec_to_go = (long_dev  and long_span_ok  and consec_above < i_min_ema_bars)        ? (i_min_ema_bars - consec_above)   : na
int sd_span_to_go   = (short_dev and (pl1b - pl2b) < i_min_sig_bars)                        ? (i_min_sig_bars - (pl1b - pl2b))  : na
int sd_consec_to_go = (short_dev and short_span_ok and consec_below < i_min_ema_bars)        ? (i_min_ema_bars - consec_below)   : na

string ld_note = long_dev ? (not na(ld_span_to_go) and not na(ld_consec_to_go) ? str.tostring(ld_span_to_go) + "b span / " + str.tostring(ld_consec_to_go) + "b EMA" : not na(ld_span_to_go) ? str.tostring(ld_span_to_go) + "b to span" : str.tostring(ld_consec_to_go) + "b to EMA") : ""
string sd_note = short_dev ? (not na(sd_span_to_go) and not na(sd_consec_to_go) ? str.tostring(sd_span_to_go) + "b span / " + str.tostring(sd_consec_to_go) + "b EMA" : not na(sd_span_to_go) ? str.tostring(sd_span_to_go) + "b to span" : str.tostring(sd_consec_to_go) + "b to EMA") : ""

string dev_tier_l = sp_long  ? "S" : "A"
string dev_tier_s = sp_short ? "S" : "A"

// ─── SCORE + TIER ─────────────────────────────────────────────────────────────
bool is_long_active  = long_setup  or long_watch1 or long_watch2
bool is_short_active = short_setup or short_watch1 or short_watch2
bool any_signal      = is_long_active or is_short_active

int   grade_ago = long_setup ? long_breakout_ago : (short_setup ? short_breakout_ago : na)
bool  grade_vol = not na(grade_ago) and volume[grade_ago] > avg_vol[grade_ago] * 1.2
float g_range   = not na(grade_ago) ? (high[grade_ago] - low[grade_ago]) : 0.0
float g_body    = not na(grade_ago) ? math.abs(close[grade_ago] - open[grade_ago]) : 0.0
bool  grade_mom = g_range > 0.0 and g_body / g_range >= 0.6

bool score_bounce  = is_long_active ? long_bounce_ok  : short_bounce_ok
bool score_pattern = is_long_active ? sp_long : sp_short
bool score_mom     = (long_setup or short_setup) and grade_mom
bool score_vol     = (long_setup or short_setup) and grade_vol
int  active_score  = (score_bounce ? 1 : 0) + (score_pattern ? 1 : 0) + (score_mom ? 1 : 0) + (score_vol ? 1 : 0)

bool   is_hold  = long_setup ? long_holding : (short_setup ? short_holding : false)
string scenario = (long_watch1 or short_watch1 or long_watch2 or short_watch2) ? "WATCH" : is_hold ? "HOLD" : "BO"
string tier     = not any_signal ? "—" : (long_watch1 or short_watch1) ? "S" : (long_watch2 or short_watch2) ? "A" : active_score >= 3 ? "S" : active_score == 2 ? "A" : active_score == 1 ? "B" : "C"

// ─── TIER HELPERS ────────────────────────────────────────────────────────────
tier_bg(t) =>
    switch t
        "S"  => color.new(color.yellow,  0)
        "A"  => color.new(color.lime,   15)
        "B"  => color.new(color.green,  20)
        "W1" => color.new(color.orange,  0)
        "W2" => color.new(color.blue,   20)
        =>      color.new(color.teal,   30)

tier_fg(t) =>
    (t == "S" or t == "A") ? color.black : color.white

// ─── VISUAL TRENDLINES + BOUNCE HIGHLIGHT ────────────────────────────────────
var line  long_line     = na
var line  short_line    = na
var box   bounce_box    = na
var box   breakout_box  = na
var label bounce_lbl    = na
var label breakout_lbl  = na

if barstate.islast
    if long_piv_ok and long_no_wick and long_touches >= i_min_touches
        color tl_col = long_breakout ? color.new(color.green, 0) : long_span_ok ? color.new(color.orange, 0) : color.new(color.blue, 40)
        float proj = ph1 + long_slope * float(bar_index + 30 - ph1b)
        line.delete(long_line)
        long_line := line.new(ph2b, ph2, bar_index + 30, proj, color=tl_col, width=2)

    if short_piv_ok and short_no_wick and short_touches >= i_min_touches
        color tl_col = short_breakout ? color.new(color.red, 0) : short_span_ok ? color.new(color.orange, 0) : color.new(color.blue, 40)
        float proj = pl1 + short_slope * float(bar_index + 30 - pl1b)
        line.delete(short_line)
        short_line := line.new(pl2b, pl2, bar_index + 30, proj, color=tl_col, width=2)

    box.delete(bounce_box)
    label.delete(bounce_lbl)
    bounce_box := na
    bounce_lbl := na
    if not na(long_bounce_bar)
        int off = bar_index - long_bounce_bar
        bounce_box := box.new(long_bounce_bar, high[off], long_bounce_bar + 1, low[off],
             bgcolor=color.new(color.lime, 50), border_color=color.new(color.lime, 0), border_width=2)
        bounce_lbl := label.new(long_bounce_bar, low[off], "B",
             style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.black, size=size.small)
    else if not na(short_bounce_bar)
        int off = bar_index - short_bounce_bar
        bounce_box := box.new(short_bounce_bar, high[off], short_bounce_bar + 1, low[off],
             bgcolor=color.new(color.red, 50), border_color=color.new(color.red, 0), border_width=2)
        bounce_lbl := label.new(short_bounce_bar, high[off], "B",
             style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

    box.delete(breakout_box)
    label.delete(breakout_lbl)
    breakout_box := na
    breakout_lbl := na
    if long_breakout
        int bk = na(long_breakout_ago) ? long_any_cross_ago : long_breakout_ago
        if not na(bk)
            breakout_box := box.new(bar_index - bk, high[bk], bar_index - bk + 1, low[bk],
                 bgcolor=color.new(color.orange, 50), border_color=color.new(color.orange, 0), border_width=2)
            breakout_lbl := label.new(bar_index - bk, high[bk], "BO",
                 style=label.style_label_down, color=color.new(color.orange, 0), textcolor=color.black, size=size.small)
    else if short_breakout
        int bk = na(short_breakout_ago) ? short_any_cross_ago : short_breakout_ago
        if not na(bk)
            breakout_box := box.new(bar_index - bk, high[bk], bar_index - bk + 1, low[bk],
                 bgcolor=color.new(color.orange, 50), border_color=color.new(color.orange, 0), border_width=2)
            breakout_lbl := label.new(bar_index - bk, low[bk], "BO",
                 style=label.style_label_up, color=color.new(color.orange, 0), textcolor=color.black, size=size.small)

// ─── MACHINE-READABLE LABEL OUTPUT ───────────────────────────────────────────
// Format: "DIRECTION|TIER|SCENARIO|TOUCHES|EMA_BARS|ATR"
var label long_lbl    = na
var label short_lbl   = na
var label lwatch1_lbl   = na
var label swatch1_lbl   = na
var label lwatch2_lbl   = na
var label swatch2_lbl   = na
var label ldev_lbl      = na
var label sdev_lbl      = na
var label ldev_note_lbl = na
var label sdev_note_lbl = na

if long_setup
    string txt = "LONG|" + tier + "|" + scenario + "|" + str.tostring(long_touches) + "|" + str.tostring(consec_above) + "|" + str.tostring(atr_val, "#.####")
    label.delete(long_lbl)
    long_lbl := label.new(bar_index, high * 1.001, txt,
         style=label.style_label_down, color=tier_bg(tier), textcolor=tier_fg(tier), size=size.small)

if short_setup
    string txt = "SHORT|" + tier + "|" + scenario + "|" + str.tostring(short_touches) + "|" + str.tostring(consec_below) + "|" + str.tostring(atr_val, "#.####")
    label.delete(short_lbl)
    short_lbl := label.new(bar_index, low * 0.999, txt,
         style=label.style_label_up, color=tier_bg(tier), textcolor=tier_fg(tier), size=size.small)

if long_watch1
    string txt = "LONG|" + tier + "|WATCH|" + str.tostring(long_touches) + "|" + str.tostring(consec_above) + "|" + str.tostring(atr_val, "#.####")
    label.delete(lwatch1_lbl)
    lwatch1_lbl := label.new(bar_index, high * 1.001, txt,
         style=label.style_label_down, color=tier_bg(tier), textcolor=tier_fg(tier), size=size.small)

if short_watch1
    string txt = "SHORT|" + tier + "|WATCH|" + str.tostring(short_touches) + "|" + str.tostring(consec_below) + "|" + str.tostring(atr_val, "#.####")
    label.delete(swatch1_lbl)
    swatch1_lbl := label.new(bar_index, low * 0.999, txt,
         style=label.style_label_up, color=tier_bg(tier), textcolor=tier_fg(tier), size=size.small)

if long_watch2
    string txt = "LONG|" + tier + "|WATCH|" + str.tostring(long_touches) + "|" + str.tostring(consec_above) + "|" + str.tostring(atr_val, "#.####")
    label.delete(lwatch2_lbl)
    lwatch2_lbl := label.new(bar_index, high * 1.001, txt,
         style=label.style_label_down, color=tier_bg(tier), textcolor=tier_fg(tier), size=size.small)

if short_watch2
    string txt = "SHORT|" + tier + "|WATCH|" + str.tostring(short_touches) + "|" + str.tostring(consec_below) + "|" + str.tostring(atr_val, "#.####")
    label.delete(swatch2_lbl)
    swatch2_lbl := label.new(bar_index, low * 0.999, txt,
         style=label.style_label_up, color=tier_bg(tier), textcolor=tier_fg(tier), size=size.small)

if long_dev
    string txt = "LONG|" + dev_tier_l + "|DEV|" + str.tostring(long_touches) + "|" + str.tostring(consec_above) + "|" + str.tostring(atr_val, "#.####")
    label.delete(ldev_lbl)
    ldev_lbl := label.new(bar_index, high * 1.001, txt,
         style=label.style_label_down, color=tier_bg(dev_tier_l), textcolor=tier_fg(dev_tier_l), size=size.tiny)
    label.delete(ldev_note_lbl)
    ldev_note_lbl := label.new(bar_index, low * 0.997, ld_note,
         style=label.style_label_up, color=color.new(color.gray, 40), textcolor=color.white, size=size.tiny)

if short_dev
    string txt = "SHORT|" + dev_tier_s + "|DEV|" + str.tostring(short_touches) + "|" + str.tostring(consec_below) + "|" + str.tostring(atr_val, "#.####")
    label.delete(sdev_lbl)
    sdev_lbl := label.new(bar_index, low * 0.999, txt,
         style=label.style_label_up, color=tier_bg(dev_tier_s), textcolor=tier_fg(dev_tier_s), size=size.tiny)
    label.delete(sdev_note_lbl)
    sdev_note_lbl := label.new(bar_index, high * 1.003, sd_note,
         style=label.style_label_down, color=color.new(color.gray, 40), textcolor=color.white, size=size.tiny)

// ─── PLOTS ───────────────────────────────────────────────────────────────────
plot(ema_plot, "Daily EMA 20", color=color.new(color.blue, 0), linewidth=1)

// ─── SETUP CONDITIONS TABLE ──────────────────────────────────────────────────
var table setup_tbl = na

if barstate.islast
    bool tbl_valid = any_signal or long_piv_ok or short_piv_ok

    if not tbl_valid
        if not na(setup_tbl)
            table.delete(setup_tbl)
            setup_tbl := na
    else
        bool   is_long_tbl  = is_long_active or (not is_short_active and consec_above >= 1)
        string dir_txt      = is_long_tbl ? "▲ LONG" : "▼ SHORT"
        color  c_met        = color.new(color.green, 20)
        color  c_nmet       = color.new(color.red,   20)
        color  c_gray       = color.new(color.gray,  50)
        color  c_det        = color.new(color.gray,  70)
        color  hdr_bg       = any_signal ? tier_bg(tier) : color.new(color.gray, 60)
        color  hdr_fg       = any_signal ? tier_fg(tier) : color.white
        bool   is_watch_tbl = long_watch1 or short_watch1 or long_watch2 or short_watch2 or long_dev or short_dev
        int    b_ago        = is_long_tbl ? long_breakout_ago : short_breakout_ago
        bool   c_break      = is_long_tbl ? long_breakout : short_breakout
        string d_break      = is_watch_tbl ? "—" : not c_break ? "—" : (na(b_ago) or b_ago == 0) ? "now" : str.tostring(b_ago) + "b"
        bool   c_vol        = not is_watch_tbl and score_vol
        int    vol_pct      = (c_break and not na(b_ago)) ? math.round((volume[b_ago] / avg_vol[b_ago] - 1) * 100) : 0
        string d_vol        = is_watch_tbl ? "—" : c_break ? ((vol_pct >= 0 ? "+" : "") + str.tostring(vol_pct) + "%") : "—"
        bool   c_mom        = not is_watch_tbl and score_mom
        float  bo_range     = (c_break and not na(b_ago)) ? (high[b_ago] - low[b_ago]) : 0.0
        float  bo_body      = (c_break and not na(b_ago)) ? math.abs(close[b_ago] - open[b_ago]) : 0.0
        int    body_pct     = bo_range > 0.0 ? math.round(bo_body / bo_range * 100) : 0
        string d_mom        = is_watch_tbl ? "—" : c_break ? str.tostring(body_pct) + "%" : "—"
        string flags_txt    = (near_ath ? "★ATH " : "") + (near_pdh ? "★PDH" : "")

        if not na(setup_tbl)
            table.delete(setup_tbl)
        setup_tbl := table.new(position.top_right, 3, 7,
             bgcolor=color.new(color.gray, 85), border_color=color.new(color.gray, 60),
             border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)

        string score_txt = any_signal ? str.tostring(active_score) + "/4" : ""
        string hdr_right = tier != "—" ? "[" + tier + "] " + scenario : ""
        table.cell(setup_tbl, 0, 0, dir_txt,   text_color=hdr_fg, bgcolor=hdr_bg, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 0, score_txt, text_color=hdr_fg, bgcolor=hdr_bg, text_size=size.small)
        table.cell(setup_tbl, 2, 0, hdr_right, text_color=hdr_fg, bgcolor=hdr_bg, text_size=size.small, text_halign=text.align_right)

        string d_bounce = is_long_tbl ? long_bounce_pat : short_bounce_pat
        table.cell(setup_tbl, 0, 1, "Bounce EMA", text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 1, score_bounce ? "✓" : "✗", text_color=color.white, bgcolor=score_bounce ? c_met : c_nmet, text_size=size.small)
        table.cell(setup_tbl, 2, 1, d_bounce, text_color=color.white, bgcolor=c_det, text_size=size.small)

        table.cell(setup_tbl, 0, 2, "Pattern", text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 2, score_pattern ? "✓" : "✗", text_color=color.white, bgcolor=score_pattern ? c_met : c_nmet, text_size=size.small)
        table.cell(setup_tbl, 2, 2, score_pattern ? (is_long_tbl ? long_bounce_pat : short_bounce_pat) : "—", text_color=color.white, bgcolor=c_det, text_size=size.small)

        color bo_bg = is_watch_tbl ? c_gray : (c_break ? c_met : c_nmet)
        table.cell(setup_tbl, 0, 3, "BO Candle", text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 3, is_watch_tbl ? "—" : (c_break ? "✓" : "✗"), text_color=color.white, bgcolor=bo_bg, text_size=size.small)
        table.cell(setup_tbl, 2, 3, d_break, text_color=color.white, bgcolor=c_det, text_size=size.small)

        color vol_bg = is_watch_tbl ? c_gray : (c_vol ? c_met : c_nmet)
        table.cell(setup_tbl, 0, 4, "Volume", text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 4, is_watch_tbl ? "—" : (c_vol ? "✓" : "✗"), text_color=color.white, bgcolor=vol_bg, text_size=size.small)
        table.cell(setup_tbl, 2, 4, d_vol, text_color=color.white, bgcolor=c_det, text_size=size.small)

        color mom_bg = is_watch_tbl ? c_gray : (c_mom ? c_met : c_nmet)
        table.cell(setup_tbl, 0, 5, "Momentum", text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 5, is_watch_tbl ? "—" : (c_mom ? "✓" : "✗"), text_color=color.white, bgcolor=mom_bg, text_size=size.small)
        table.cell(setup_tbl, 2, 5, d_mom, text_color=color.white, bgcolor=c_det, text_size=size.small)

        table.cell(setup_tbl, 0, 6, "Flags", text_color=color.white, bgcolor=c_det, text_size=size.small, text_halign=text.align_left)
        table.cell(setup_tbl, 1, 6, str.length(flags_txt) > 0 ? "★" : "—", text_color=color.yellow, bgcolor=c_det, text_size=size.small)
        table.cell(setup_tbl, 2, 6, flags_txt, text_color=color.yellow, bgcolor=c_det, text_size=size.small)
